# Orion Voice — Production Configuration
# Copy this to .env and customize values

# Server
ORION_VOICE_HOST=0.0.0.0
ORION_VOICE_PORT=5000
ORION_VOICE_WORKERS=4
ORION_VOICE_REQUEST_TIMEOUT=120
ORION_VOICE_MAX_PAYLOAD_MB=50
ORION_VOICE_PRODUCTION=true

# Security — CHANGE THESE IN PRODUCTION
ORION_VOICE_API_KEY=your-secret-api-key-here
ORION_VOICE_REQUIRE_AUTH=true
ORION_VOICE_RATE_LIMIT=10
ORION_VOICE_RATE_LIMIT_WINDOW=60
ORION_VOICE_KEY_PASSWORD=your-key-encryption-password

# TLS (optional — use a reverse proxy like nginx instead)
# ORION_VOICE_TLS_CERT=/path/to/cert.pem
# ORION_VOICE_TLS_KEY=/path/to/key.pem

# Logging
ORION_VOICE_LOG_LEVEL=INFO
ORION_VOICE_LOG_FORMAT=json
# ORION_VOICE_LOG_FILE=/var/log/orion-voice/server.log

# ML
# ORION_VOICE_MODEL_PATH=/path/to/speaker_model.pt
# ORION_VOICE_SCALER_PATH=/path/to/scaler.npz
# ORION_VOICE_FHE_CONFIG_PATH=/path/to/fhe_config.yml
ORION_VOICE_DECISION_THRESHOLD=0.5
